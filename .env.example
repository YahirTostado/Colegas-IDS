# ===================================================================
#  Plantilla de variables de entorno — IDS Corporativo
# -------------------------------------------------------------------
#  1. Copia este archivo a ".env"      ->  cp .env.example .env
#  2. Rellena con TUS valores reales (usuario válido + contraseñas fuertes).
#  3. NUNCA subas ".env" al repositorio (ya está en .gitignore).
#  4. Cífralo con OpenSSL:               ->  ./secrets/encrypt_env.sh
# ===================================================================

# ───────────────────────────────────────────────
#  Credenciales del ADMINISTRADOR del sistema
# ───────────────────────────────────────────────
#  Se usan SOLO en el primer arranque: la app las convierte en un hash
#  PBKDF2 con sal aleatoria dentro de config/settings.json. A partir de
#  ese momento NO se vuelven a leer del .env.
#  Elige un usuario válido y una contraseña SEGURA (mín. 8 caracteres,
#  mezcla mayúsculas, minúsculas, números y símbolos).
#  Sugerencia: tras el primer arranque puedes borrar la línea
#  IDS_ADMIN_PASSWORD del .env (la app ya guarda solo el hash).
IDS_ADMIN_USER=admin_red
IDS_ADMIN_PASSWORD=Cambia_Esta_Clave#2026

# ───────────────────────────────────────────────
#  Cuenta SMTP que ENVÍA las alertas
# ───────────────────────────────────────────────
#  Nota: el correo del ADMIN que RECIBE las alertas NO va aquí; vive en
#  config/settings.json porque no es secreto y debe cambiarse fácilmente.
#  Aquí solo va la cuenta emisora (credencial sensible).
#  App Password de 16 caracteres (Gmail: Verificación en 2 pasos ->
#  https://myaccount.google.com/apppasswords). NO es tu contraseña normal.
IDS_SMTP_USER=tucuenta@gmail.com
IDS_SMTP_PASSWORD=xxxxxxxxxxxxxxxx