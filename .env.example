# ─────────────────────────────────────────────────────────────────
# IDS Corporativo — Variables de entorno (CREDENCIALES SENSIBLES)
# Copia este archivo como ".env" y rellena tus datos reales.
# NUNCA subas el archivo ".env" a Git ni lo compartas.
# ─────────────────────────────────────────────────────────────────

# Cuenta Gmail que ENVÍA las alertas
IDS_SMTP_USER=tu_correo@gmail.com

# Contraseña de aplicación de Google (16 caracteres, sin espacios)
# Cómo obtenerla: Google Account → Seguridad → Contraseñas de aplicaciones
IDS_SMTP_PASSWORD=xxxx xxxx xxxx xxxx
